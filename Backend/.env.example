# Clinica Victorio - Variables de Entorno

# Base de datos
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=clinicavictorio
DB_PORT=3306

# JWT
JWT_SECRET=tu_secreto_seguro_aqui

# Puerto del servidor
PORT=3000

# URLs
FRONTEND_URL=http://localhost:5173

# Correo (Nodemailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=tu_email@gmail.com
MAIL_PASS=tu_contrasena_app
MAIL_FROM=Clinica Victorio <no-reply@clinicavictorio.com>

# ==========================================
# CONFIGURACIÓN LDAP (Opcional)
# Descomenta y configura si deseas usar 
# autenticación con directorio institucional
# ==========================================

# Habilitar LDAP (true/false)
# LDAP_ENABLED=false

# Servidor LDAP (ej: ldap://servidor.dominio.com o ldaps:// para SSL)
# LDAP_URL=ldap://localhost:389

# Base DN para búsqueda (ej: dc=miInstitucion,dc=edu,dc=mx)
# LDAP_BASE_DN=dc=example,dc=com

# Usuario admin para bind (dejar vacío para bind anónimo)
# LDAP_BIND_DN=cn=admin,dc=example,dc=com

# Contraseña del admin
# LDAP_BIND_PASSWORD=

# Filtro de búsqueda (sustituye {{username}} por el usuario)
# Para OpenLDAP: (uid={{username}})
# Para Active Directory: (sAMAccountName={{username}})
# LDAP_SEARCH_FILTER=(uid={{username}})

# Atributos LDAP
# LDAP_USERNAME_ATTR=uid
# LDAP_EMAIL_ATTR=mail
# LDAP_NAME_ATTR=cn

# =========================
# RASP (Datadog)
# =========================
DD_APPSEC_ENABLED=true